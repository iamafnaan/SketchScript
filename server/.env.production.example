# Production Environment Variables
PORT=8000
NODE_ENV=production

# Database (Render provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@host:port/database

# CORS Origins (Update with your Render frontend URL)
CORS_ORIGINS=https://your-frontend.onrender.com

# Session Settings
SESSION_SECRET=your-super-secure-session-secret-here-minimum-32-chars

# Optional: Code execution timeout
CODE_EXECUTION_TIMEOUT=30000
