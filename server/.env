# SketchScript Server Environment Variables

# Server Configuration
PORT=8000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sketchscript
DB_USER=postgres
DB_PASSWORD=password

# Docker Configuration (for code execution)
DOCKER_HOST=unix:///var/run/docker.sock

# Security Settings
CORS_ORIGIN=http://localhost:3000

# Session Configuration
SESSION_TIMEOUT_HOURS=24
PARTICIPANT_TIMEOUT_MINUTES=30

# Code Execution Limits
CODE_EXECUTION_TIMEOUT=30000
CODE_MEMORY_LIMIT=134217728
CODE_CPU_LIMIT=50000

# Cleanup Configuration
CLEANUP_INTERVAL_MINUTES=60 